{
    "name": "adsmod-ml-client",
    "private": true,
    "version": "2.3.0",
    "type": "module",
    "scripts": {
        "dev": "ng serve --host 127.0.0.1 --port 5174 --proxy-config proxy.conf.cjs",
        "build": "npm run verify:angular-migration && npm run write:runtime-config && ng build",
        "preview": "node scripts/preview-serve.mjs",
        "lint": "npm run verify:angular-migration && eslint . --max-warnings 0",
        "test": "ng test --watch=false",
        "test:unit": "ng test --watch=false",
        "visual:baseline": "playwright test -c playwright.config.ts --update-snapshots",
        "visual:compare": "playwright test -c playwright.config.ts",
        "verify:angular-migration": "node scripts/verify-angular-migration.mjs",
        "write:runtime-config": "node scripts/write-runtime-config.mjs"
    },
    "dependencies": {
        "@angular/animations": "^21.2.9",
        "@angular/common": "^21.2.9",
        "@angular/compiler": "^21.2.9",
        "@angular/core": "^21.2.9",
        "@angular/forms": "^21.2.9",
        "@angular/platform-browser": "^21.2.9",
        "@angular/router": "^21.2.9",
        "dompurify": "^3.2.7",
        "katex": "^0.16.25",
        "marked": "^16.4.0",
        "rxjs": "^7.8.2",
        "tslib": "^2.8.1",
        "zone.js": "~0.16.0"
    },
    "devDependencies": {
        "@angular/build": "^21.2.9",
        "@angular/cli": "^21.2.9",
        "@angular/compiler-cli": "^21.2.9",
        "@playwright/test": "^1.54.2",
        "@types/node": "^22.15.33",
        "@types/dompurify": "^3.2.0",
        "@typescript-eslint/eslint-plugin": "^8.15.0",
        "@typescript-eslint/parser": "^8.15.0",
        "eslint": "^9.15.0",
        "jsdom": "^26.1.0",
        "vitest": "^4.0.8",
        "typescript": "~5.9.3"
    }
}
