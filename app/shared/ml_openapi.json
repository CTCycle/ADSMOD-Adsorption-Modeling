            "title": "Source"
          },
          "dataset_name": {
            "type": "string",
            "maxLength": 128,
            "minLength": 1,
            "pattern": "^[A-Za-z0-9_. -]+$",
            "title": "Dataset Name"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "source",
          "dataset_name"
        ],
        "title": "DatasetSelection"
      },
