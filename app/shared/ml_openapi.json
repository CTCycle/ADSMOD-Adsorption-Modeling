              {
                "type": "null"
              }
            ],
            "title": "Normalization Stats"
          }
        },
        "type": "object",
        "required": [
          "available"
        ],
        "title": "DatasetInfoResponse"
      },
      "DatasetSelection": {
        "properties": {
          "source": {
            "type": "string",
            "enum": [
              "nist",
              "uploaded"
