  "components": {
    "schemas": {
      "CheckpointDetailInfo": {
        "properties": {
          "name": {
            "type": "string",
            "title": "Name"
          },
          "epochs_trained": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Epochs Trained"
          },
          "final_loss": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Final Loss"
          },
          "final_accuracy": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Final Accuracy"
          },
          "is_compatible": {
            "type": "boolean",
            "title": "Is Compatible",
            "default": true
          }
        },
        "type": "object",
        "required": [
          "name"
        ],
        "title": "CheckpointDetailInfo"
      },
      "CheckpointFullDetailsResponse": {
        "properties": {
          "name": {
            "type": "string",
            "title": "Name"
          },
          "configuration": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Configuration"
          },
          "metadata": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/TrainingMetadata"
              },
              {
                "type": "null"
              }
            ]
          },
          "history": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "History"
          }
        },
        "type": "object",
        "required": [
          "name"
        ],
        "title": "CheckpointFullDetailsResponse"
      },
      "CheckpointsResponse": {
        "properties": {
          "checkpoints": {
            "items": {
              "$ref": "#/components/schemas/CheckpointDetailInfo"
            },
            "type": "array",
            "title": "Checkpoints"
          }
        },
        "type": "object",
        "required": [
          "checkpoints"
        ],
        "title": "CheckpointsResponse"
      },
      "DatasetBuildRequest": {
        "properties": {
          "sample_size": {
            "type": "number",
            "maximum": 1.0,
            "minimum": 0.01,
            "title": "Sample Size",
            "default": 1.0
          },
          "validation_size": {
            "type": "number",
            "maximum": 0.5,
            "minimum": 0.05,
            "title": "Validation Size",
            "default": 0.2
          },
          "min_measurements": {
            "type": "integer",
            "maximum": 100.0,
            "minimum": 1.0,
            "title": "Min Measurements",
            "default": 1
          },
          "max_measurements": {
            "type": "integer",
            "maximum": 500.0,
            "minimum": 5.0,
            "title": "Max Measurements",
            "default": 30
          },
          "smile_sequence_size": {
            "type": "integer",
            "maximum": 100.0,
            "minimum": 5.0,
            "title": "Smile Sequence Size",
            "default": 20
          },
          "max_pressure": {
            "type": "number",
            "maximum": 100000.0,
            "minimum": 100.0,
            "title": "Max Pressure",
            "default": 10000.0
          },
          "max_uptake": {
            "type": "number",
            "maximum": 1000.0,
            "minimum": 1.0,
            "title": "Max Uptake",
            "default": 20.0
          },
          "reference_checkpoint": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 128,
                "minLength": 1,
                "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]{0,127}$"
              },
              {
                "type": "null"
              }
            ],
            "title": "Reference Checkpoint"
          },
          "datasets": {
            "items": {
              "$ref": "#/components/schemas/DatasetSelection"
            },
            "type": "array",
            "minItems": 1,
            "title": "Datasets"
          },
          "dataset_label": {
            "type": "string",
            "maxLength": 64,
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9 _-]{0,63}$",
            "title": "Dataset Label",
            "default": "default"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "title": "DatasetBuildRequest"
      },
      "DatasetInfoResponse": {
        "properties": {
          "available": {
            "type": "boolean",
            "title": "Available"
          },
          "dataset_label": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 64,
                "minLength": 1,
                "pattern": "^[A-Za-z0-9][A-Za-z0-9 _-]{0,63}$"
              },
              {
                "type": "null"
              }
            ],
            "title": "Dataset Label"
          },
          "created_at": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Created At"
          },
          "sample_size": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Sample Size"
          },
          "validation_size": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Validation Size"
          },
          "min_measurements": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Min Measurements"
          },
          "max_measurements": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Max Measurements"
          },
          "smile_sequence_size": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Smile Sequence Size"
          },
          "max_pressure": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Max Pressure"
          },
          "max_uptake": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Max Uptake"
          },
          "total_samples": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Total Samples"
          },
          "train_samples": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Train Samples"
          },
          "validation_samples": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Validation Samples"
          },
          "smile_vocabulary_size": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Smile Vocabulary Size"
          },
          "adsorbent_vocabulary_size": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Adsorbent Vocabulary Size"
          },
          "normalization_stats": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
